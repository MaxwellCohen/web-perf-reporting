  <div
    data-testid="gauge"
  >
    First Contentful Paint
  </div>
  <div
    data-testid="gauge"
  >
    Interaction to Next Paint
  </div>
  <div
    data-testid="gauge"
  >
    Largest Contentful Paint
  </div>
</div>
`;
