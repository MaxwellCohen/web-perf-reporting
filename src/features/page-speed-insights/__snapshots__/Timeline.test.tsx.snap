exports[`Timeline > renders thumbnail buttons for each timeline item 1`] = `"<div class="px-4"><h3 class="text-lg font-bold"> Timeline</h3><div class="mt-3 flex flex-row gap-2 align-top"><div type="button" aria-haspopup="dialog" aria-expanded="false" aria-controls="radix-_r_0_" data-state="closed"><button class="rounded-md border-2  p-2 hover:scale-105 z-0"><img alt="timeline image at 100" width="80" src="data:image/png;base64,a"><div>100 ms</div></button></div><div type="button" aria-haspopup="dialog" aria-expanded="false" aria-controls="radix-_r_0_" data-state="closed"><button class="rounded-md border-2  p-2 hover:scale-105 z-0"><img alt="timeline image at 200" width="80" src="data:image/png;base64,b"><div>200 ms</div></button></div></div></div>"`;

