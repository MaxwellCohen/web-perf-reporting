                data-grouped="false"
                data-placeholder="false"
                data-row-expanded="false"
                style="width: 150px;"
              >
                <span
                  data-testid="ms-value"
                >
                  300
                   ms
                </span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
`;
