# Google PageSpeed Insights / CrUX API key
PAGESPEED_INSIGHTS_API=

# Turso (libSQL) database
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=

# PostHog analytics (client)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cloudflare PageSpeed worker (server-side only; no NEXT_PUBLIC_ prefix)
WORKER_URL=https://web-perf-report-cf.to-email-max.workers.dev

# Optional Sentry (defaults are baked into sentry.*.config.ts if unset)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
